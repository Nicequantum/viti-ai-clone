{
  "name": "benz-tech",
  "private": true,
  "version": "3.0.1",
  "scripts": {
    "dev": "next dev",
    "validate:env": "node scripts/validate-env.mjs",
    "build": "node scripts/validate-env.mjs && prisma generate && prisma migrate deploy && next build",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:reencrypt": "npx tsx scripts/reencrypt-legacy-data.ts",
    "db:studio": "prisma studio",
    "test": "tsx --test tests/**/*.test.ts",
    "test:integration": "tsx --test tests/integration/**/*.test.ts",
    "setup:tesseract": "node scripts/copy-tesseract-assets.mjs",
    "postinstall": "prisma generate && npm run setup:tesseract"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "@vercel/blob": "^2.4.1",
    "@vercel/kv": "^3.0.0",
    "bcryptjs": "^3.0.2",
    "jose": "^6.0.11",
    "jspdf": "^3.0.1",
    "lucide-react": "^0.468.0",
    "next": "^15.3.3",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.5",
    "tesseract.js": "^5.1.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.4",
    "prisma": "^6.9.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
